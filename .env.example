# Claude subscription auth (NOT an API key) — from `claude setup-token`
CLAUDE_CODE_OAUTH_TOKEN=

# Sippar rails
SIPPAR_BASE_URL=https://sippar.network
SIPPAR_ACCESS_TOKEN=

# Budget
BUDGET_CAP_USD=5
PER_TX_MAX_USD=0.20

# Agent wallets (ICP principals — PUBLIC identifiers, signed by ICP threshold sigs;
# these are addresses, not keys). Single-agent uses AGENT_PRINCIPAL; swarm/devswarm/
# farcaster use SWARM_PRINCIPALS (comma-separated, one funded principal per agent).
AGENT_PRINCIPAL=
SWARM_PRINCIPALS=

# Optional knobs
SWARM_MODEL=claude-sonnet-4-6
# DEVSWARM_DISCUSS_TURNS=8
# DEVSWARM_BUILD_TURNS=30
# FARCASTER_ROUNDS=1
