# Igigi Swarm — environment template. Copy to .env and fill in. NEVER commit your .env.

# Sippar settlement API (the on-chain payment rail).
SIPPAR_BASE_URL=https://sippar.network
SIPPAR_ACCESS_TOKEN=            # access token for the Sippar agent-pay API

# Reasoning brain — the swarm runs on bought inference (off any provider's cap).
OPENROUTER_API_KEY=             # your OpenRouter key (https://openrouter.ai)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
INFERENCE_PROVIDER=openrouter
AGENT_ENGINE=deepseek
# (Alternative: a Claude subscription token from `claude setup-token`)
# CLAUDE_CODE_OAUTH_TOKEN=

# Settlement scope: 1 = Tempo-only catalog (100% MPP); unset = full cross-chain catalog.
MPP_ONLY=1

# Agent wallets (ICP principals — PUBLIC identifiers signed by ICP threshold sigs, not keys).
# provision.mjs generates + funds these and writes the list to .provisioned-principals.txt.
# Single-agent runs can set AGENT_PRINCIPAL; the swarm reads SWARM_PRINCIPALS (comma-separated).
AGENT_PRINCIPAL=
SWARM_PRINCIPALS=

# Budget envelope (hard caps; agents also reason within these).
SWARM_CAP_USD=0.10             # shared external-spend ceiling across the whole swarm
BUDGET_CAP_USD=0.05            # per-agent working budget
PER_TX_MAX_USD=0.04            # max single purchase
SWARM_MODEL=claude-sonnet-4-6
